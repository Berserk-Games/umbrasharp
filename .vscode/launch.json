{
	"version": "0.2.0",
	"configurations": [
		{
			"name": ".NET Core Debugger (launch)",
			"type": "coreclr",
			"request": "launch",
			"program": "${workspaceFolder}/src/UmbraSharp.CLI/bin/Debug/net8.0/UmbraSharp.CLI.dll"
		},
		{
			"name": ".NET Core Debugger (attach)",
			"type": "coreclr",
			"request": "attach",
			"processId": "${command:dotrush.pickProcess}"
		}
	]
}
